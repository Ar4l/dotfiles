
# macOS Finder metadata
.DS_Store

# vim plugins (plug.vim is installed on first startup)
plug.vim
plugged/

# don't care too much about small changes to btop
files/.config/btop/

# nvim rewrites plugin pins whenever it updates; not worth tracking
files/.config/nvim/lazy-lock.json

# k9s writes these at runtime (views.yaml stays tracked)
files/.config/k9s/aliases.yaml
files/.config/k9s/config.yaml


# pyrate scratch captures (raw API requests; contain session tokens)
bin/pyrate/temp/
