# Command Shorthands
function mkd() {
  mkdir "$1"
  cd "$1"
}

function cl() {
  cd "$1"
  ls 
}

# create a pytorch docker container named aral if it does not yet exist
# and enter the container 
#
# Takes a single argument, corresponding to which GPUs to use
function dock() {
  container_name=aral-pytorch

  # copies kitty conf, and enters zsh if available
  function safe_enter() {
    # copy kitty infocmp over to the container
    infocmp -a xterm-kitty | docker exec -i "$container_name" tic -x -o /root/.terminfo /dev/stdin &> /dev/null
    # check if zsh is in the container, defaulting to bash
    # TODO: this does not work as intended, always using bash atm.
    shell=$(docker exec $container_name sh -c 'if command -v zsh > /dev/null 2>&1; then echo zsh; else echo bash; fi')
    # run this in the container
    docker exec -it -e TERM="$TERM" $container_name $shell
  }

  # if container exists and is running, enter it 
  if [ "$(docker ps -q -f name=$container_name)" ]; then
    safe_enter

  else 

    # Prompt user to enter which GPUs to use
    nvidia-smi
    read -p "Enter which GPUs to use (e.g., 0,1): " gpus
    echo "You selected GPUs: $gpus"

    # if the container does not exist, download it if necessary 
    if ! [ "$(docker ps -aqf name=$container_name)" ]; then
      tag='24.08-py3'
      echo "running nvidia/pytorch:$tag"

      # Collect all dotfiles and dotfolders in your home directory
      MOUNTS=""
      for dotfile in ${HOME}/.[^.]*; do
        MOUNTS+="-v $dotfile:/root/$(basename $dotfile) "
      done

      # gpus to use
      # interactive & detached
      # mount dotfiles to /root
      # home dir into /workspace
      docker run --name $container_name --gpus "\"device=$gpus\"" -itd $MOUNTS -v ${HOME}:/workspace --ulimit memlock=-1 --ulimit stack=67108864 nvcr.io/nvidia/pytorch:$tag
      safe_enter

    # the container exists but is not running
    # this is trickier, as we cannot change the GPUs without
    # committing the container to an image.
    else 
      echo 'not yet implemented: container exists but is not running'
    fi
  fi
}

# not super clean, but I also want one for plain ubuntu
function ubuntu() {
  container_name=aral-ubuntu

  # copies kitty conf, and enters zsh if available
  function safe_enter() {
    # copy kitty infocmp over to the container
    infocmp -a xterm-kitty | docker exec -i "$container_name" tic -x -o /root/.terminfo /dev/stdin &> /dev/null
    # check if zsh is in the container, defaulting to bash
    # TODO: this does not work as intended, always using bash atm.
    shell=$(docker exec $container_name sh -c 'if command -v zsh > /dev/null 2>&1; then echo zsh; else echo bash; fi')
    # run this in the container
    docker exec -it -e TERM="$TERM" $container_name $shell
  }

  # if container exists and is running, enter it 
  if [ "$(docker ps -q -f name=$container_name)" ]; then
    safe_enter

  else 

    # Prompt user to enter which GPUs to use
    nvidia-smi
    read -p "Enter which GPUs to use (e.g., 0,1): " gpus
    echo "You selected GPUs: $gpus"

    # if the container does not exist, download it if necessary 
    if ! [ "$(docker ps -aqf name=$container_name)" ]; then
      container_id=ubuntu:latest
      echo "running $container_id"

      # Collect all dotfiles and dotfolders in your home directory
      MOUNTS=""
      for dotfile in ${HOME}/.[^.]*; do
        MOUNTS+="-v $dotfile:/root/$(basename $dotfile) "
      done

      # gpus to use
      # interactive & detached
      # mount dotfiles to /root
      # home dir into /workspace
      docker run --name $container_name --gpus "\"device=$gpus\"" -itd $MOUNTS -v ${HOME}:/root --ulimit memlock=-1 --ulimit stack=67108864 $container_id
      safe_enter

    # the container exists but is not running
    # this is trickier, as we cannot change the GPUs without
    # committing the container to an image.
    else 
      echo 'not yet implemented: container exists but is not running'
    fi
  fi
}



function killge() {

  if [ "$#" -lt 1 ]; then
    echo 'Usage: killge <higher_than_pid>'
    return
  fi

  # prompt the user first
  to_kill=$(ps aux | awk -v treshold=$1 '$2 >= treshold')
  echo "$to_kill"
  echo '> Kill the above processes? (y/n)'
  read -r answer

  if [[ "$answer" == "y" ]]; then
    echo "Confirmed. Proceeding..."

    pids_to_kill=$(echo "$to_kill" | awk '{print $2}' | tail -n +2)
    kill $pids_to_kill

  elif [[ "$answer" == "n" ]]; then
    echo "Aborted."
  else
    echo "Invalid input. Aborted."
  fi
}


# shouldn't run this too often because it lags the GPU
alias nv='watch -d -n "10" nvidia-smi'

alias gis='git status'
alias giff='git diff'

# launch claude, upgrading the brew cask first if a newer version is out.
# queries formulae.brew.sh directly (~0.2s): `brew outdated` only compares
# against local tap metadata, which goes stale without a slow `brew update`.
if [ -d "${HOMEBREW_PREFIX:-/opt/homebrew}/Caskroom/claude-code" ]; then
  claude() {
    local caskroom="${HOMEBREW_PREFIX:-/opt/homebrew}/Caskroom/claude-code"
    local installed latest
    installed=$(command ls -1 "$caskroom" | sort -V | tail -1)
    latest=$(curl -fsS --max-time 2 https://formulae.brew.sh/api/cask/claude-code.json 2>/dev/null \
      | sed -n 's/.*"version":"\([^"]*\)".*/\1/p')
    if [ -n "$latest" ] && [ "$latest" != "$installed" ]; then
      echo "claude-code $installed -> $latest, upgrading..."
      brew update --quiet && brew upgrade --cask claude-code
      echo 'note: if Downloads/Desktop access EPERMs in tmux after this, restart the tmux server from kitty (TCC re-attribution)'
    fi
    command claude "$@"
  }
fi

# cd into a git worktree by branch name; `cwt -` jumps back to the previous worktree
cwt() {
  local target
  if [ "$1" = "-" ]; then
    target="$OLDWT"
  else
    target="$(git worktree list --porcelain | awk -v b="$1" '
      /^worktree / {path=$2}
      $0 == "branch refs/heads/" b {print path; exit}
    ')"
  fi
  OLDWT="$PWD"
  cd "$target"
}

_cwt_branches() {
  git worktree list --porcelain 2>/dev/null \
    | awk '/^branch refs\/heads\//{sub(/^branch refs\/heads\//,""); print}'
}

if [ -n "$ZSH_VERSION" ]; then
  _cwt() {
    local -a branches
    branches=(${(f)"$(_cwt_branches)"})
    compadd "$@" -- $branches
  }
  # compdef requires compinit, which hasn't run yet when .aliases is sourced;
  # defer via a one-shot precmd hook that fires after compinit completes.
  autoload -Uz add-zsh-hook
  _cwt_register() {
    compdef _cwt cwt
    add-zsh-hook -d precmd _cwt_register
  }
  add-zsh-hook precmd _cwt_register
elif [ -n "$BASH_VERSION" ]; then
  _cwt_complete() {
    COMPREPLY=($(compgen -W "$(_cwt_branches)" -- "${COMP_WORDS[COMP_CWORD]}"))
  }
  complete -F _cwt_complete cwt
fi
