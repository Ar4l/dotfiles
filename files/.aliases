# kitty stuff; see https://sw.kovidgoyal.net/kitty/kittens/ssh/
# copies over some config files to the host
# guard on KITTY_WINDOW_ID, not TERM: inside tmux TERM is tmux-256color but
# we're still running under kitty. The reverse tunnel (for remote kitty
# control) only works when kitty is actually listening on a socket.
if [[ -n "$KITTY_WINDOW_ID" || "$TERM" =~ 'kitty' ]]; then
  if [[ -n "$KITTY_LISTEN_ON" ]]; then
    alias s='kitty +kitten ssh -R 50000:${KITTY_LISTEN_ON#*:}'
  else
    alias s='kitty +kitten ssh'
  fi
fi

if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    #alias dir='dir --color=auto'
    #alias vdir='vdir --color=auto'
fi

